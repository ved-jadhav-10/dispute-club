{
  "name": "dispute-club",
  "private": true,
  "version": "0.1.0",
  "workspaces": [
    "apps/*"
  ],
  "scripts": {
    "dev": "concurrently \"npm run dev:worker\" \"npm run dev:web\"",
    "dev:worker": "npm run dev -w @dispute-club/worker",
    "dev:web": "npm run dev -w @dispute-club/web",
    "build": "npm run build -w @dispute-club/worker && npm run build -w @dispute-club/web",
    "deploy:worker": "npm run deploy -w @dispute-club/worker"
  },
  "devDependencies": {
    "concurrently": "^9.0.1"
  }
}
